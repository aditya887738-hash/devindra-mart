rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn(){ return request.auth != null; }
    function userDoc(){ return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function role(){ return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? userDoc().data.role : null; }
    function isAdmin(){ return role() == 'admin'; }
    function isBilling(){ return role() == 'billing' || role() == 'merchant'; }
    function isRider(){ return role() == 'rider'; }
    match /settings/{id} { allow read: if true; allow write: if isAdmin(); }
    match /stores/{id} { allow read: if true; allow write: if isAdmin(); }
    match /products/{id} { allow read: if true; allow write: if isAdmin() || isBilling(); }
    match /users/{uid} { allow read, write: if signedIn() && (request.auth.uid == uid || isAdmin()); }
    match /orders/{id} { allow create: if signedIn(); allow read, update: if isAdmin() || isBilling() || isRider() || (signedIn() && resource.data.customerId == request.auth.uid); }
    match /riders/{id} { allow read, write: if isAdmin() || (signedIn() && request.auth.uid == id); }
    match /khata/{id} { allow read, write: if signedIn(); }
    match /payments/{id} { allow read, write: if signedIn(); }
    match /notifications/{id} { allow read, write: if signedIn(); }
    match /banners/{id} { allow read: if true; allow write: if isAdmin(); }
    match /schemes/{id} { allow read: if true; allow write: if isAdmin(); }
    match /fcmTokens/{id} { allow read, write: if signedIn(); }
    match /riderLocations/{id} { allow read: if isAdmin() || isBilling(); allow write: if isRider(); }
    match /logs/{id} { allow read, write: if isAdmin(); }
    match /backups/{id} { allow read, write: if isAdmin(); }
  }
}
